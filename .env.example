# Supabase (필수)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 데이터 통합 관리 AI 파싱 API (선택, 미설정 시 Mock 사용)
# VITE_MIGRATION_PARSE_API=https://your-api.com/parse

# Edge Function analyze-quote (견적서/원가표 AI 분석) — Supabase Secrets에 설정
# supabase secrets set GOOGLE_GEMINI_API_KEY=AIza...

# 채널톡 웹훅 (Edge Function 시크릿 — Supabase 대시보드 > Edge Functions > channel-talk-webhook > Secrets에서 설정)
# CHANNELTALK_WEBHOOK_SECRET=your-webhook-sign-secret
# 웹훅 URL: https://<project-ref>.supabase.co/functions/v1/channel-talk-webhook

# 구글 시트 양방향 동기화 — 앱 [최종 확정] 시 해당 행 상태·견적가 갱신 (Code.gs doPost 웹앱 URL)
# Apps Script에서 웹앱 배포 후 URL을 여기에 설정. 선택: SYNC_WEBAPP_TOKEN은 스크립트 속성에 동일하게 설정.
# VITE_GOOGLE_SHEET_SYNC_URL=https://script.google.com/macros/s/xxxxxxxx/exec
# VITE_GOOGLE_SHEET_SYNC_TOKEN=your-optional-secret
