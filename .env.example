# Supabase (필수)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 보안 원칙:
# - 브라우저에서 읽는 값만 VITE_ 접두사를 사용합니다.
# - API secret, webhook URL, 서비스 토큰, AI 비밀키는 VITE_로 두지 말고 서버사이드 비밀값으로만 관리하세요.

# 데이터 통합 관리 AI 파싱 API (선택, 미설정 시 Mock 사용)
# VITE_MIGRATION_PARSE_API=https://your-api.com/parse

# Edge Function analyze-quote (견적서/원가표 AI 분석) — Supabase Secrets에 설정
# supabase secrets set GOOGLE_GEMINI_API_KEY=AIza...

# 채널톡 웹훅 (Edge Function 시크릿 — Supabase 대시보드 > Edge Functions > channel-talk-webhook > Secrets에서 설정)
# CHANNELTALK_WEBHOOK_SECRET=your-webhook-sign-secret
# CHANNELTALK_ACCESS_KEY=your-channel-talk-access-key
# CHANNELTALK_ACCESS_SECRET=your-channel-talk-access-secret
# CHANNELTALK_BOT_NAME=your-channel-bot-name
# SHOWROOM_PUBLIC_BASE_URL=https://findgagu-os-cursor.vercel.app/public/showroom
# (채널톡 자동 메시지의 링크 — 로그인 없이 열리는 맞춤형 공개 쇼룸)
# 선택: SHOWROOM_PREVIEW_SITE_LIMIT=6 (Edge에서 먼저 보여 줄 현장 수, 1–50)
# 웹훅 URL: https://<project-ref>.supabase.co/functions/v1/channel-talk-webhook

# 구글 시트 양방향 동기화는 서버사이드에서 호출하세요.
# Apps Script 토큰은 브라우저 환경변수에 두면 안 됩니다.
# VITE_GOOGLE_SHEET_SYNC_URL=https://script.google.com/macros/s/xxxxxxxx/exec
